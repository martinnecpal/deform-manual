---
layout: none
---
[
  {% assign docs = site.docs | where: "lang", "en" %}
  {% for doc in docs %}
  {
    "title": {{ doc.title | default: doc.name | jsonify }},
    "url": {{ doc.url | relative_url | jsonify }},
    "content": {{ doc.content | strip_html | strip_newlines | truncatewords: 80 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
