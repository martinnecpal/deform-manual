{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: Serve (GitHub Pages mode)",
      "type": "shell",
      "command": "bundle exec jekyll serve",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*\\.(?:md|html)):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*Regenerating:",
          "endsPattern": "^\\s*\\.\\.\\.done"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Jekyll: Serve (dev mode, baseurl='')",
      "type": "shell",
      "command": "bundle exec jekyll serve --config _config.yml,_config_dev.yml",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*\\.(?:md|html)):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*Regenerating:",
          "endsPattern": "^\\s*\\.\\.\\.done"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Jekyll: Build",
      "type": "shell",
      "command": "bundle exec jekyll build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
